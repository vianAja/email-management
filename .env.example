GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
SESSION_SECRET=replace-with-a-long-random-secret

# Local development
APP_BASE_URL=http://localhost:5173
REDIRECT_URL=http://localhost:5173/api/auth/callback
PORT=3100

# Frontend dev helper
VITE_API_BASE_URL=
VITE_BACKEND_URL=http://localhost:3100
VITE_PORT=5173
VITE_PREVIEW_PORT=4173

# Docker host port override (optional)
APP_HOST_PORT=9000

# Optional: ngrok token if you expose Docker app publicly
NGROK_AUTH=

# Vercel note:
# In production, APP_BASE_URL and REDIRECT_URL should point to your final Vercel domain
# or custom domain, for example:
# APP_BASE_URL=https://your-app.vercel.app
# REDIRECT_URL=https://your-app.vercel.app/api/auth/callback
