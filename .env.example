CLIENT_ID=your-google-oauth-client-id
CLIENT_SECRET=your-google-oauth-client-secret
SESSION_SECRET=replace-with-a-long-random-secret

# Local development
APP_BASE_URL=http://localhost:5173
REDIRECT_URL=http://localhost:5173/api/auth/callback
PORT=3100

# Frontend dev helper
VITE_API_BASE_URL=
VITE_BACKEND_URL=http://localhost:3100
VITE_PORT=5173
VITE_PREVIEW_PORT=4173

# Docker host port override (optional)
APP_HOST_PORT=9000

# Optional: ngrok token if you expose Docker app publicly
NGROK_AUTH=

# Vercel production note:
# APP_BASE_URL=https://email.najwan.my.id
# REDIRECT_URL=https://email.najwan.my.id/api/auth/callback
#
# Backward compatibility:
# GOOGLE_OAUTH_CLIENT_ID and GOOGLE_OAUTH_CLIENT_SECRET are still supported,
# but CLIENT_ID and CLIENT_SECRET are now the preferred names.
